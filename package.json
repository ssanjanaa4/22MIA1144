{
  "name": "exam1-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "vehicle_scheduling",
    "notification_system",
    "shared"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run -w vehicle_scheduling build && npm run -w notification_system build",
    "dev": "concurrently \"npm:dev:vehicle\" \"npm:dev:notification\"",
    "dev:vehicle": "npm run -w vehicle_scheduling dev",
    "dev:notification": "npm run -w notification_system dev",
    "lint": "eslint \"**/*.ts\" --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^8.46.0",
    "prettier": "^2.10.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.1",
    "nodemon": "^2.0.22",
    "@types/node": "^20.5.1",
    "@types/express": "^4.17.21"
  }
}
